PORT=5000
MONGODB_URI=mongodb://localhost:27017/zapply
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
CLIENT_URL=http://localhost:5173

# Admin credentials (KEEP THESE PRIVATE)
ADMIN_USERNAME=zapply_admin
ADMIN_PASSWORD=ZapplyAdmin@2024!Secure
ADMIN_SECRET_KEY=your-admin-secret-key-change-this

# OTP Config (mock for dev - set to true to use console log)
MOCK_OTP=true
OTP_EXPIRY_MINUTES=2

# Twilio (for production OTP)
# TWILIO_ACCOUNT_SID=your_twilio_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# TURN Server (for video calls across different networks)
TURN_SERVER_URL=stun:stun.l.google.com:19302
# TURN_USERNAME=
# TURN_CREDENTIAL=
